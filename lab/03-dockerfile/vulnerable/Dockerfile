# ============================================================
#  보너스 · 취약한 Dockerfile (일부러 잘못 짰습니다)
#  목표: 컨테이너 이미지에서 위험한 습관 3가지를 찾아보세요.
# ============================================================
FROM node:latest
# 👀 ① latest 태그 — 어떤 버전인지 알 수 없고 재현이 안 됨

WORKDIR /app
ADD . /app
# 👀 ② ADD 대신 COPY 권장 (ADD는 원격 URL·압축 해제까지 해서 위험)

RUN npm install

EXPOSE 3000
CMD ["node", "server.js"]
# 👀 ③ USER 지정 없음 → 컨테이너가 root로 실행됨
# 👀 ④ HEALTHCHECK 없음 → 컨테이너가 살아있는지 확인 불가
